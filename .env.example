# Copy to .env and fill in the values. Never commit .env.

# Required in production (the app refuses to start without it when FLASK_ENV=production)
JWT_SECRET_KEY=

# Anthropic API key used by the RAG pipeline (rewriter, grader, answerer)
ANTHROPIC_API_KEY=

# Model used to generate answers (grader/rewriter always use claude-haiku-4-5)
ANSWER_MODEL=claude-sonnet-4-6

# Optional: Notion integration token for syncing pages
NOTION_TOKEN=

# Optional overrides (sensible defaults exist for all of these)
# FLASK_ENV=development
# DATABASE_URL=sqlite:///instance/app.db
# UPLOAD_FOLDER=
# VECTOR_STORE_FOLDER=
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# RAG_TOP_K=4
# RATE_LIMIT=60/minute
# FRONTEND_ORIGINS=http://localhost:5173
